# InsureFlowAI Connection
INSUREFLOW_API_URL=https://insureflow-ai-production.up.railway.app
INSUREFLOW_API_KEY=your_admin_api_key_here

# Scraper Config
TARGET_STATES=MI,TX,OH,AL,AZ
MAX_PER_STATE=50
RATE_LIMIT_MS=2000

# Optional: Skip tracing (future feature)
SKIP_TRACING_API_KEY=optional_fastappend_key
